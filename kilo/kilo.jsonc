        "list": "allow",
        "task": "deny",
        "skill": "allow",
        "lsp": "allow",
        "todoread": "deny",
        "todowrite": "deny",
        "websearch": "deny",
        "webfetch": "deny",
        "doom_loop": "deny",
      },
      "variant": "low",
