# ---- Port mappings ----
ROUTER_PORT=20128
WEBUI_PORT=20129
OMNIROUTE_PORT=20130
PROXY_PORT=20131

# ---- Host paths (override per-machine; avoid editing docker-compose.yml) ----
# 9router data dir, mounted into the 9router container
# NINEROUTER_DATA_DIR=/home/firman/.9router
# open-webui data dir, mounted into the 9router-webui container
# WEBUI_DATA_DIR=/home/firman/.9router-webui
# proxy rule dir (strip.json/inject.json), mounted read-only into the proxy container
# PROXY_CONFIG_DIR=/home/firman/.9router

# ---- 9router-webui ----
# NINEROUTER_API_KEY=sk-your-key-here

# ---- Proxy ----
# TARGET_URL=http://9router:20128
# Directory holding strip.json/inject.json, mounted read-only into the proxy container.
# Defaults to the repo dir (uses the committed rules). Override with a host-specific path.
# PROXY_CONFIG_DIR=/home/firman/.9router
